# 统一用 LF 存储（项目在 Linux/Docker 运行），避免 Windows CRLF 污染仓库
* text=auto eol=lf

# 明确的文本类型
*.py    text eol=lf
*.md    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.toml  text eol=lf
*.txt   text eol=lf
*.sh    text eol=lf
Dockerfile* text eol=lf
Makefile    text eol=lf

# 二进制（不做行尾转换）
*.png   binary
*.jpg   binary
*.jpeg  binary
*.mp4   binary
*.wav   binary
*.onnx  binary
*.db    binary
